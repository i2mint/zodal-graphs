{
  "name": "@zodal/graph-compute",
  "version": "0.0.1",
  "description": "Renderer-agnostic graph-theory and provenance overlay engine for zodal-graphs (computed once on the graphology hub, drawn on any renderer)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zodal/graph-core": "workspace:*"
  },
  "peerDependencies": {
    "graphology": "^0.25.0 || ^0.26.0"
  },
  "devDependencies": {
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
