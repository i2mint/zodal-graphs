{
  "name": "@zodal/graph-sigma",
  "version": "0.0.1",
  "description": "Large-sparse WebGL viz renderer for zodal-graphs (sigma.js over the graphology hub, with overlay styling)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./headless": {
      "import": { "types": "./dist/headless.d.ts", "default": "./dist/headless.js" },
      "require": { "types": "./dist/headless.d.cts", "default": "./dist/headless.cjs" }
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zodal/graph-core": "workspace:*",
    "@zodal/graph-ui": "workspace:*"
  },
  "peerDependencies": {
    "graphology": "^0.25.0 || ^0.26.0",
    "react": "^18.0.0 || ^19.0.0",
    "sigma": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.0",
    "react": "^19.0.0",
    "sigma": "^3.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
